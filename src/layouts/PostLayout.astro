---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  date: Date;
  description?: string;
  readingTime?: number;
}

const { title, date, description, readingTime } = Astro.props;

const formattedDate = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
const isoDate = date.toISOString();
---

<BaseLayout title={title} description={description}>
  <article>
    <h1>{title}</h1>
    <p class="post-meta">
      <time datetime={isoDate}>{formattedDate}</time>
      {readingTime ? <> · {readingTime} minute read</> : null}
    </p>
    <slot />
    <hr />
    <p class="muted"><a href="/">← All posts</a></p>
  </article>
</BaseLayout>
